class SniperCharacter extends SparrowCharacter {

	function new() {
		super('sniper');
	}

	function onCreate(event:ScriptEvent) {
		super.onCreate(event);

		GameOverSubState.musicSuffix = '-nobf';
		GameOverSubState.blueBallSuffix = '-sniper';

		PauseSubState.musicSuffix = '-geek';
	}
}