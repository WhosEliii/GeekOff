import funkin.play.character.SparrowCharacter;

class LucyOpponentCharacter extends SparrowCharacter
{
  function new()
  {
    super('lucy-opponent');
  }

  override function applyAnimationOffsets(name:String):Void
	{
		if (this.flipX)
		{
			var offsets = animationOffsets.get(name);
			this.animOffsets = [(-offsets[0]) + (frameWidth - width), offsets[1]];
		}
		else
			super.applyAnimationOffsets(name);
	}
}