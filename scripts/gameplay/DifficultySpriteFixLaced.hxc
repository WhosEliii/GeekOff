import funkin.play.PlayState;
import funkin.modding.module.Module;
import funkin.util.Constants;

class DifficultySpriteFixLaced extends Module
{
    function new()
        {
            super('DifficultySpriteFixLaced');
        }    

    function onCreate(event)
        {
            super.onCreate(event);
			if (!Constants.DEFAULT_DIFFICULTY_LIST_FULL.contains('laced')) Constants.DEFAULT_DIFFICULTY_LIST_FULL.push("laced");
        }
}