import funkin.play.song.Song;
import funkin.play.PlayState;
import funkin.Paths;
import funkin.play.cutscene.VideoCutscene;
import funkin.graphics.video.FunkinVideoSprite;

import funkin.play.PlayStatePlaylist;

class CaliClearSong extends Song {
  var hasPlayedCutscene:Bool;
  public var video1:FunkinVideoSprite;

	public function new() {
		super('cali-clear');

    hasPlayedCutscene = false;
	}

  public override function onCountdownStart(event:CountdownScriptEvent):Void {
		super.onCountdownStart(event);

    if (!PlayStatePlaylist.isStoryMode) hasPlayedCutscene = true; // Skip cutscene if you're playing the song from freeplay

    if (!hasPlayedCutscene) {
      trace('Pausing countdown to play a video cutscene (`stonerstix`)');

      hasPlayedCutscene = true;

      event.cancel(); // CANCEL THE COUNTDOWN!

      VideoCutscene.play(Paths.videos('MainCutscene')); // Will look for modName/videos/videos/MainCutscene.mp4
    }
	}

  function onSongLoaded(e) {
    super.onSongLoaded(e);

    video1 = new FunkinVideoSprite(-200, -90);
    video1.zIndex = 25;
    video1.bitmap.volumeAdjust = 0;
    video1.load(Paths.videos('cloudsNshi')); // Will look for modName/videos/videos/cloudsNshi.mp4
    video1.scrollFactor.set(0, 0);
    video1.scale.set(1.15, 1.15);

  }

  public function onStepHit(event:ScriptEvent)
  {
    super.onStepHit(event);

    if (event.step == 959)
    {
      video1.play();
      PlayState.instance.currentStage.add(video1);
      PlayState.instance.currentStage.refresh();
    }
  }

  /**
   * Replay the cutscene after leaving the song.
   */
  function onCreate(event:ScriptEvent):Void
  {
    super.onCreate(event);

    hasPlayedCutscene = false; // We reset the cutscene "state", so that we can play the cutscene again (after leaving the song and reentering for example)
  }

  public function onSongRetry(event:SongRetryEvent)
  {
    super.onSongRetry(event);
    hasPlayedCutscene = true; // Skips the cutscene if you retry the song through pause menu or after a gameover

    PlayState.instance.currentStage.remove(video1); // Removes the video to avoid duplicating it
    PlayState.instance.currentStage.refresh();
  }
}
